//Code Part
module WaterLevelController (
    input wire clk,       // Clock input
    input wire reset,     // Reset input
    input wire water_sensor_low,   // Low water level sensor input
    input wire water_sensor_mid,   // Mid water level sensor input
    input wire water_sensor_high,  // High water level sensor input
    output reg pump_on       // Output to control pump (assuming active-high)
);

// State definitions
parameter [1:0] IDLE = 2'b00;    // Idle state
parameter [1:0] LOW_LEVEL = 2'b01;   // Low water level detected
parameter [1:0] MID_LEVEL = 2'b10;   // Mid water level detected
parameter [1:0] HIGH_LEVEL = 2'b11;  // High water level detected

// Internal state register
reg [1:0] state, next_state;

// Sequential logic
always @(posedge clk or posedge reset) begin
    if (reset) begin
        state <= IDLE;
    end else begin
        state <= next_state;
    end
end

// Combinational logic
always @* begin
    case (state)
        IDLE: begin
            if (water_sensor_low) begin
                next_state = LOW_LEVEL;
            end else if (water_sensor_mid) begin
                next_state = MID_LEVEL;
            end else if (water_sensor_high) begin
                next_state = HIGH_LEVEL;
            end else begin
                next_state = IDLE;
            end
        end
        LOW_LEVEL: begin
            if (water_sensor_mid) begin
                next_state = MID_LEVEL;
            end else if (water_sensor_high) begin
                next_state = HIGH_LEVEL;
            end else begin
                next_state = LOW_LEVEL;
            end
        end
        MID_LEVEL: begin
            if (water_sensor_high) begin
                next_state = HIGH_LEVEL;
            end else if (!water_sensor_low && !water_sensor_mid) begin
                next_state = IDLE;
            end else begin
                next_state = MID_LEVEL;
            end
        end
        HIGH_LEVEL: begin
            if (!water_sensor_high) begin
                next_state = MID_LEVEL;
            end else begin
                next_state = HIGH_LEVEL;
            end
        end
        default: next_state = IDLE;
    endcase
end

// Output control
always @* begin
    case (state)
        IDLE: begin
            pump_on = 1'b0;   // Pump off
        end
        LOW_LEVEL: begin
            pump_on = 1'b1;   // Pump on
        end
        MID_LEVEL: begin
            pump_on = 1'b1;   // Pump on
        end
        HIGH_LEVEL: begin
            pump_on = 1'b0;   // Pump off
        end
        default: pump_on = 1'b0;
    endcase
end

endmodule
